# Cardcom — copy relevant lines to Koyeb / .env
#
# Three modes (pick one):
#
# 1) Local QuickScribe simulation (green page, no Cardcom API):
#    SIMULATION_MODE=true
#    CARDCOM_ENABLED=true
#
# 2) Production site + Cardcom SANDBOX (real Cardcom hosted page, test cards):
#    SIMULATION_MODE=false
#    CARDCOM_ENABLED=true
#    CARDCOM_SIMULATION=false
#    CARDCOM_SANDBOX=true
#    CARDCOM_TERMINAL_NUMBER=1000
#    CARDCOM_API_NAME=<from Cardcom merchant portal>
#    PUBLIC_BASE_URL=https://www.getquickscribe.com
#
# 3) Production + Cardcom LIVE (real charges):
#    Same as (2) but production terminal from Cardcom, CARDCOM_SANDBOX=false
#
# Webhook (sandbox or live): https://<PUBLIC_BASE_URL>/api/cardcom/webhook
# Test card (sandbox): 4580000000000000 — see Cardcom developer docs for expiry/CVV.

SIMULATION_MODE=false
CARDCOM_ENABLED=true
CARDCOM_SIMULATION=false
CARDCOM_SANDBOX=true
CARDCOM_TERMINAL_NUMBER=1000
CARDCOM_API_NAME=
PUBLIC_BASE_URL=https://www.getquickscribe.com
