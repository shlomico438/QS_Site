# Medical + SageMaker (Koyeb production) — copy relevant keys into Koyeb env / local .env
# Do not commit real secrets.

# --- Medical live transcription (default: AWS Transcribe Streaming) ---
# Primary path: browser mic → /ws/transcribe → AWS Transcribe Streaming (requires GeventWebSocketWorker on Linux/Koyeb).
# IAM on Site credentials: transcribe:StartStreamTranscription
# MEDICAL_USE_AWS_TRANSCRIBE_STREAM=true
# MEDICAL_TRANSCRIBE_STREAM_LANGUAGE=he-IL
# AWS region for Transcribe Streaming (required if AWS_REGION=auto for R2):
# MEDICAL_TRANSCRIBE_STREAM_REGION=eu-north-1
# Set MEDICAL_USE_AWS_TRANSCRIBE_STREAM=false to use SageMaker async only (below).

# RunPod only: skip early /run at sign-s3 (non-medical / legacy RunPod path).
RUNPOD_SKIP_WARMUP=true

# SageMaker only: skip per-upload warmup at sign-s3 / multipart-init (use session warmup + trigger_processing).
AWS_SKIP_WARMUP=true

MEDICAL_TRANSCRIPTION_ENGINE=sagemaker
SAGEMAKER_MEDICAL_ENDPOINT_NAME=quickscribe-transcribe-async

# Site URL for SageMaker worker → /api/gpu_started (required in production).
# PUBLIC_BASE_URL=https://www.getquickscribe.com

# Optional: min seconds between session warmups per Site instance (default 600).
# MEDICAL_SESSION_WARMUP_INTERVAL_SEC=600

# Show "starting" after session warmup POST while AWS still reports cap=0 (default 900).
# MEDICAL_WARMUP_STALE_SEC=900
# MEDICAL_WARMUP_STARTING_SEC=900

# Scale-in detection: EventBridge (Application Auto Scaling) → SNS → HTTPS webhook.
# MEDICAL_WARMUP_SNS_TOPIC_ARN=arn:aws:sns:eu-north-1:ACCOUNT:quickscribe-medical-warmup-scale
# MEDICAL_SAGEMAKER_VARIANT_NAME=AllTraffic
# Webhook: {PUBLIC_BASE_URL}/api/aws/sns/medical_endpoint_scale
# Setup: docs/aws-medical-endpoint-scale-webhook.md
# Status poll (global, same for all doctors): GET /api/medical_endpoint_status
# Green UI when endpoint_ready=true (AWS capacity >= 1 && endpoint InService)

# Legacy CloudWatch CPU alarm on same SNS topic (off by default):
# MEDICAL_WARMUP_ALLOW_CLOUDWATCH_ALARM=true
# MEDICAL_SCALE_IN_ALARM_NAME=quickscribe-medical-scale-in

# Optional TTL fallback if SNS is not configured (default off).
# MEDICAL_WARMUP_USE_TTL_FALLBACK=true
# MEDICAL_WARMUP_READY_TTL_SEC=2700

# Simulation off in production
# SIMULATION_MODE=false
